PRISMA_CLI_BINARY_TARGETS="debian-openssl-3.0.x"

# --- Configuration PostgreSQL (Serverless / Neon.tech) ---
# INFO SCALABILITÉ: Avec un environnement Serverless, on utilise deux URLs distinctes :
# 1. DATABASE_URL utilise un "Connection Pooler" (PgBouncer).
#    C'est INDISPENSABLE pour que l'app (Prisma Client) ne sature pas la base sous forte charge.
DATABASE_URL="postgresql://NEON_DB_USER_NAME:YOUR_PASSWORD@ep-frosty-paper-alcwsw5d-pooler.c-3.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# 2. DIRECT_URL contourne le pooler.
#    C'est OBLIGATOIRE pour les migrations de schéma Prisma (connexions transactionnelles exclusives).
DIRECT_URL="postgresql://NEON_DB_USER_NAME:YOUR_PASSWORD@ep-frosty-paper-alcwsw5d.c-3.eu-central-1.aws.neon.tech/neondb?sslmode=require"

GROQ_API_KEY="YOUR_GROQ_LLM_KEY"
GROQ_BASE_URL="https://api.groq.com/openai/v1"
